# Backend API base URL (server-side only — do NOT prefix with NEXT_PUBLIC_)
# The Next.js API routes use this to proxy requests to the backend.
# For Vercel deployment, set this to the public backend endpoint.
BACKEND_API_URL=https://your-backend.example.com

# Client-side API base URL for direct requests from browser code.
NEXT_PUBLIC_API_URL=https://your-backend.example.com

# Stellar testnet configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
