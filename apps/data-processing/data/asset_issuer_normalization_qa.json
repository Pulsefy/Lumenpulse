{
  "metadata": {
    "dataset_name": "asset_issuer_normalization_qa",
    "version": "1.0.0",
    "description": "Validation dataset for Stellar asset issuer-aware normalization. Each entry maps a raw asset input to its expected canonical normalized output. Used for regression testing of the normalize_asset() function.",
    "created_at": "2026-06-24",
    "schema": {
      "test_id": "Unique test case identifier",
      "category": "Test category grouping (native, issued, edge_case, malformed)",
      "description": "Human-readable description of what this case validates",
      "raw_input": "The raw input to pass to normalize_asset(). Type matches input_type.",
      "input_type": "Expected Python type of raw_input: 'string', 'dict', or 'tuple'",
      "expected_output": "Expected canonical NormalizedAsset fields (null if should_succeed=false)",
      "should_succeed": "Whether normalization is expected to succeed (true) or raise an error (false)"
    },
    "canonical_form_spec": {
      "native": "asset_type='native', asset_code='XLM', asset_issuer=null, canonical='native'",
      "issued_alphanum4": "asset_type='credit_alphanum4', asset_code='CODE' (uppercase, <=4 chars), asset_issuer='G...' (56-char), canonical='CODE:ISSUER'",
      "issued_alphanum12": "asset_type='credit_alphanum12', asset_code='CODE' (uppercase, 5-12 chars), asset_issuer='G...' (56-char), canonical='CODE:ISSUER'"
    }
  },
  "test_cases": [
    {
      "test_id": "native_001",
      "category": "native",
      "description": "Lowercase 'xlm' string is recognized as native asset",
      "raw_input": "xlm",
      "input_type": "string",
      "expected_output": {
        "asset_type": "native",
        "asset_code": "XLM",
        "asset_issuer": null,
        "canonical": "native"
      },
      "should_succeed": true
    },
    {
